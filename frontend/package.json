{
  "name": "humblee-frontend",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "//": "These scripts can also be run from the project root via: npm run build / npm run dev:*",
    "build": "npm run build --workspaces",
    "build:media-manager": "npm run build --workspace=apps/media-manager",
    "build:blocks": "npm run build --workspace=apps/blocks",
    "build:templates": "npm run build --workspace=apps/templates",
    "build:toolbar": "npm run build --workspace=apps/toolbar",
    "build:session-monitor": "npm run build --workspace=apps/session-monitor",
    "build:personalization": "npm run build --workspace=apps/personalization",
    "dev:media-manager": "npm run dev --workspace=apps/media-manager",
    "dev:blocks": "npm run dev --workspace=apps/blocks",
    "dev:templates": "npm run dev --workspace=apps/templates",
    "dev:toolbar": "npm run dev --workspace=apps/toolbar",
    "dev:session-monitor": "npm run dev --workspace=apps/session-monitor",
    "dev:personalization": "npm run dev --workspace=apps/personalization",
    "build:page-editor": "npm run build --workspace=apps/page-editor",
    "dev:page-editor": "npm run dev --workspace=apps/page-editor"
  }
}
